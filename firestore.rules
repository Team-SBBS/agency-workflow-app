rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Top-level function for authentication check
    function isAuthenticated() {
      return request.auth != null;
    }

    // Default rule: Deny all by default for safety
    match /{document=**} {
      allow read, write: if false;
    }
    
    // Explicit access for application collections
    // Allow read/write for authenticated users across main resources
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated(); // Allow user creation/edits for admins 
    }
    
    match /tasks/{taskId} {
      allow read, write: if isAuthenticated();
    }
    
    match /clients/{clientId} {
      allow read, write: if isAuthenticated();
    }

    match /invoices/{invoiceId} {
      allow read, write: if isAuthenticated();
    }

    match /config/{configId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }
  }
}
